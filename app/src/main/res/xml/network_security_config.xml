<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Production default: deny cleartext traffic. Per-domain exceptions must be explicitly reviewed. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
